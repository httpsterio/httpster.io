<section class="review-album-info md:flex">
<div class="review-image"><img src="{{image}}"></div>
<dl class="review-meta" style="{% if theme %} background: var(--color-{{theme}});{%endif%}">
  <dt>title</dt> 
  <dd>{{seriesname}}</dd>
  <dt>year</dt>
  <dd>{{releaseyear}}</dd>
  <dt>platform</dt>
  <dd>{{platform}}</dd>
  <dt>episodes</dt>
  <dd>{{episodes}}</dd>
  <dt>score</dt>
  <dd>{{score}} / 100</dd>
</dl>
</section>